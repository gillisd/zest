#autoload

emulate -L zsh
setopt extendedglob
# Deliberately NOT errreturn: this loop must survive failing tests; every
# status below is checked explicitly.

print
zest_pass=0; zest_fail=0; zest_skip=0
zest_failures=()
__zest_failure_index=0

local -A opts
zparseopts -D -E -K -A opts -- n:
(( ? != 0 )) && return 1

local -a test_funcs=($@)
local filter=${opts[-n]:-}

if (( $#test_funcs == 0 )); then
  test_funcs=(${(ok)functions[(I)test_*]})
fi

if [[ -n $filter ]]; then
  test_funcs=(${(M)test_funcs:#*${filter}*})
fi

if (( $#test_funcs == 0 )); then
  zest_printerr "zest: no test_* functions found${filter:+ matching '$filter'}"
  return 1
fi

local func
local label
integer func_rc
integer setup_rc
__zest_func_index=0
__zest_func_count=$#test_funcs
for func in $test_funcs; do
  (( __zest_func_index = __zest_func_index + 1 ))
  zest_current_test=${func#test_}
  zest_current_failed=false
  zest_current_skipped=false
  zest_current_skip_msg=""
  rc=0; out=""; err=""
  func_rc=0

  if (( $+functions[$func] )); then
    __zest_run_setup_hooks
    setup_rc=$?

    if (( setup_rc == 0 )); then
      __zest_invoke_test $func
      func_rc=$?
    fi

    if (( func_rc != 0 )) && ! $zest_current_failed && ! $zest_current_skipped; then
      __zest_record_failure "test returned non-zero: $func_rc" ${functions_source[$func]:-unknown}
    fi

    __zest_run_teardown_hooks
  else
    __zest_record_failure "no such test function: $func"
  fi

  label=${zest_current_test//_/ }

  if $zest_current_skipped; then
    zest_print -n --color=yellow "SKIP"
    zest_print --color=white ": %B$label${zest_current_skip_msg:+ ($zest_current_skip_msg)}%b"
    (( zest_skip++ ))
  elif $zest_current_failed; then
    zest_print -n --color=red "FAIL"
    zest_print --color=white ": %B$label%b"
    (( zest_fail++ ))
  else
    zest_print -n --color=green "PASS"
    zest_print --color=white ": %B$label%b"
    (( zest_pass++ ))
  fi
done

print
__zest_print_results_summary
