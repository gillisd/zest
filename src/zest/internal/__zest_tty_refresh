#autoload

emulate -L zsh

if [[ -z $__zest_tty_session ]]; then
  __zest_record_failure "tty assertion used with no live session -- call tty_start first"
  return 1
fi

if [[ $__zest_tty_stale != true ]]; then
  return 0
fi

: > $__zest_tty_statefile
zpty -w -n $__zest_tty_session $'\e[99;9~'

if __zest_tty_wait_for $__zest_tty_statefile $'*\nDONE'; then
  eval "${"$(<$__zest_tty_statefile)"%$'\n'DONE}"
  typeset -g __zest_tty_stale=false
  return 0
fi

local poisoned="<tty snapshot timed out>"
typeset -g zest_tty_buffer=$poisoned
typeset -g zest_tty_cursor=$poisoned
typeset -g zest_tty_lbuffer=$poisoned
typeset -g zest_tty_rbuffer=$poisoned
typeset -g __zest_tty_stale=false
return 0
