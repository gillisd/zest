#autoload

emulate -L zsh

local results_string="$zest_pass passed, $zest_fail failed"
if (( zest_skip > 0 )); then
  results_string+=", $zest_skip skipped"
fi

if (( zest_fail > 0 )); then
  print "Failures: "
  print
  print -l -P $zest_failures
  print
  zest_printerr $results_string
  return 1
else
  zest_print --color=green $results_string
  return 0
fi
