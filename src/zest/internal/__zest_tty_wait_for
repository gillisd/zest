#autoload

emulate -L zsh

local file=$1
local pattern=$2
integer tries

for tries in {1..200}; do
  # Relieve pty backpressure before each check so the slave keeps running
  # toward the sentinel instead of blocking on a full master buffer.
  __zest_tty_drain
  if [[ -e $file && "$(<$file)" = ${~pattern} ]]; then
    return 0
  fi
  sleep 0.05
done

return 1
