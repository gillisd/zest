#autoload

emulate -L zsh

if [[ -z $__zest_tty_session ]]; then
  __zest_record_failure "tty assertion used with no live session -- call tty_start first"
  return 1
fi

zpty -w -n $__zest_tty_session $'\C-x'

if ! __zest_tty_expect "*<zest-snap>*<zest-snap-end>*"; then
  local poisoned="<tty snapshot unavailable: session ended>"
  zest_tty_buffer=$poisoned zest_tty_cursor=$poisoned
  zest_tty_lbuffer=$poisoned zest_tty_rbuffer=$poisoned zest_tty_keymap=$poisoned
  return 1
fi

# Parse the LAST snapshot block; discard any echo/redraw noise before it. Each
# field is "X:value" on its own line; the pty appends a CR we strip. Prefix
# patterns are used so this does not depend on the extendedglob option.
local block=${REPLY##*<zest-snap>}
block=${block%%<zest-snap-end>*}

local line
for line in ${(f)block}; do
  line=${line%$'\r'}
  case $line in
    (B:*) zest_tty_buffer=${line#B:}  ;;
    (C:*) zest_tty_cursor=${line#C:}  ;;
    (L:*) zest_tty_lbuffer=${line#L:} ;;
    (R:*) zest_tty_rbuffer=${line#R:} ;;
    (K:*) zest_tty_keymap=${line#K:}  ;;
  esac
done

return 0
