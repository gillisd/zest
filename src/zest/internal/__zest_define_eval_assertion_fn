#autoload

local assertion_type=${1:?}
local fn_name=${2:?}
local message=${3:?}
local defs=${4:?}
local combined_name=${assertion_type}_${fn_name}
message=${${${(qqq)message}//'{expected}'/'%B${needle}%b'}//'{actual}'/'%B${actual}%b'}
case $assertion_type in
  assert)
    eval "
      ${combined_name}() {
        emulate -L zsh
        $defs
        local message=$message

        if () { ${functions[check]} } \"\$@\"; then
          return 0
        fi

        __zest_record_failure \$message
        return 1
      }
    "
    ;;
  refutat)
    eval "
      ${combined_name//refutat/refute}() {
        emulate -L zsh
        $defs
        local message=$message

        if () { ${functions[check]} } \"\$@\"; then
          __zest_record_failure \$message
          return 1
        fi

        return 0
      }
    "
    ;;
  *)
    zest_printerr "ZEST INTERNAL ERROR: assertion type ${(qqq)assertion_type} not supported"
    return 1
esac
