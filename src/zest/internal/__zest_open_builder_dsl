#autoload

emulate -L zsh

if $__zest_builder_dsl_open; then
  return 0
fi

local fn

#
# for each of these (and whatever else is on the DSL API):
#  check
#  arg
#  assertion_message
#  refutation_message
#
# 1. If already defined by user, make a backup copy
# 2. Define the new DSL functions that end in message
# 3. The message functions will set a global variable with the message, which will be used by the generated assertion functions. This allows users to call these functions in their test files to customize messages for assertions without worrying about scoping issues.
for fn in $__zest_builder_dsl_functions; do
  if __zest_is_function_defined $fn; then
    functions -c $fn __zest_original_$fn
  fi

  if [[ $fn =~ '^.*_message$' ]]; then
    ${fn}() {
      emulate -L zsh
      local message="${@}"

      if [[ -z $message ]]; then
        zest_printerr "ZEST ERROR: $0 must be called with a non-empty message"
        return 1
      fi

      eval "typeset -g __zest_builder_dsl_var_${0}=${(q)message}"
    }
  fi
done
#
#
# Add a "typeset -p'esque" variable definition to the global __zest_builder_dsl_var_arg_defs
#
arg() {
  local name=${1}
  local type=${2:-string}
  local buf
  integer index

  if [[ -z $name ]]; then
    zest_printerr "Usage: %B$0%b <name> <type (optional)>"
    return 1
  fi

  if (( $parameters[__zest_builder_dsl_var_arg_defs] )); then
    typeset -g __zest_builder_dsl_var_arg_defs
  fi

  case $type in
    integer)
      buf+=integer
      ;;
    string)
      buf+=local
      ;;
    float)
      buf+=float
      ;;
    array)
      buf+="local -a"
      ;;
    *)
      zest_printerr "ERROR: Type %B$type%b is not acceptable"
      return 1
      ;;
  esac
  (( index = $#__zest_builder_dsl_var_arg_defs + 1 ))
  buf+=" ${name}=\${${index}}"

  __zest_builder_dsl_var_arg_defs+=($buf)
}

__zest_builder_dsl_open=true
