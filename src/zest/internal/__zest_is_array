#autoload

emulate -L zsh

# An absent or empty argument names no parameter, so it is not an array.
# (${1:?} here would abort the whole run when an empty scalar is passed
# unquoted through an assertion.)
local subject=${1:-}
local subject_type

if [[ -z $subject ]] || ! (( $+parameters[$subject] )); then
  return 1
fi

subject_type=${parameters[$subject]}

if [[ $subject_type =~ array ]]; then
  return 0
fi

return 1
