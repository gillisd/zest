#autoload

emulate -L zsh

local msg=$1
local location=${2:-${funcfiletrace[2]:-unknown}}
local heading_indent="  "
local failures_indent="     "
local NL=$'\x0a'
local base_message
local test_label=${zest_current_test//_/ }

# These strings are rendered later with prompt expansion (print -P); escape
# user-controlled text so values containing % survive verbatim.
msg=${msg//\%/%%}
test_label=${test_label//\%/%%}
location=${location//\%/%%}

(( __zest_failure_index = __zest_failure_index + 1 ))

zest_current_failed=true

zest_failures+=("${heading_indent}${__zest_failure_index}) ${test_label} %F{cyan}($location)%f")
base_message="Failure/Error: $msg"
base_message=${base_message//#/$failures_indent}
base_message=${base_message//$NL/$NL$failures_indent}
base_message="%F{red}${base_message}%f"
zest_failures+=($base_message)
