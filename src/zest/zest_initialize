#autoload

emulate -L zsh

setopt extendedglob

zmodload -F zsh/files b:zf_rm

# ── state ────────────────────────────────────────────────────────────────
typeset -gi zest_pass=0 zest_fail=0 zest_skip=0
typeset -ga zest_failures
typeset -g zest_current_test
typeset -g zest_current_failed
typeset -g zest_current_skipped=false
typeset -g zest_current_skip_msg=""

typeset -gi __zest_failure_index=0
typeset -gi __zest_func_index
typeset -gi __zest_func_count

# these are handled in a separate init path to prevent contamination with existing state. While it may look over-engineered for these 3,
# it can easily be extended to support any potentially shadowed variables
typeset -gA __zest_public_global_vars=(
  [rc]=0
  [out]="none"
  [err]="none"
  [NL]=$'\x0a'
)

typeset -ga __zest_builder_dsl_functions=(
  check
  arg
  assertion_message
  refutation_message
)

typeset -g __zest_builder_dsl_open=false

local __zest_assertion_file
for __zest_assertion_file in $__ZEST_ROOT_DIR/src/zest/assertions/*.zsh(.N); do
  source $__zest_assertion_file
done

__zest_initialize_public_global_vars
__zest_build_assertions
