#autoload

emulate -L zsh

if [[ -z $__zest_tty_session ]]; then
  __zest_record_failure "tty_source: no live session -- call tty_start first"
  return 1
fi

local arg tmp target
for arg in "$@"; do
  if (( $+functions[$arg] )); then
    # A defined function: copy its definition into the session so the same
    # function exists there under the same name. Write a widget in your
    # shell and transplant it into the pty with no file on disk, then bind
    # it with tty_run. A function name takes precedence over a like-named
    # file.
    tmp=$(mktemp)
    functions -- "$arg" > $tmp
    target=$tmp
  elif [[ -r $arg ]]; then
    tmp=""
    target=${arg:a}
  else
    __zest_record_failure "tty_source: ${(qqq)arg} is neither a defined function nor a readable file"
    return 1
  fi

  if ! __zest_tty_send_synced "source ${(q)target}"; then
    [[ -n $tmp ]] && zf_rm -f $tmp
    __zest_record_failure "tty_source: loading ${(qqq)arg} did not complete"
    return 1
  fi
  [[ -n $tmp ]] && zf_rm -f $tmp
done

return 0
