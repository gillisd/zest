#autoload

emulate -L zsh

local want=$1
__zest_tty_snapshot || return 1

if [[ $zest_tty_cursor = <-> && $want = <-> ]]; then
  (( zest_tty_cursor == want )) && return 0
elif [[ $zest_tty_cursor = $want ]]; then
  return 0
fi
__zest_record_failure "expected CURSOR at ${(qqq)want} but was at ${(qqq)zest_tty_cursor}"
return 1
