#autoload

emulate -L zsh

local unexpected=$1

__zest_tty_refresh || return 1

if [[ $zest_tty_cursor = <-> && $unexpected = <-> ]]; then
  if (( zest_tty_cursor != unexpected )); then
    return 0
  fi
elif [[ $zest_tty_cursor != $unexpected ]]; then
  return 0
fi

__zest_record_failure "expected CURSOR to not be at ${(qqq)unexpected} but was"
return 1
